# 复制为 .env 并按需填写（勿提交真实密钥）

# FAL（图像/视频等）
# FAL_KEY=

# GitHub 素材库：列表（Tree API）、上传到仓库 Contents API 均需 Token
# Classic PAT：勾选 repo；Fine-grained：对该仓库 Contents 读 + 写
# GITHUB_TOKEN=

# 素材所在仓库 owner/repo，默认与内置 Raw 仓库一致
# WORKBENCH_GITHUB_REPO=SuWeiheng200317/AI-shorts_Static_Resources
# WORKBENCH_GITHUB_DEFAULT_BRANCH=main

# Raw 与 Tree API 地址（换仓库时请与上面 owner/repo/分支 一致）
# WORKBENCH_GITHUB_ASSETS_RAW_BASE_URL=https://raw.githubusercontent.com/OWNER/REPO/main
# WORKBENCH_GITHUB_REPO_API_TREE_URL=https://api.github.com/repos/OWNER/REPO/git/trees/main?recursive=1

# 单文件上传上限（字节），默认约 95MB（GitHub 单文件约 100MB 限制）
# MAX_GITHUB_ASSET_UPLOAD_BYTES=99614720
